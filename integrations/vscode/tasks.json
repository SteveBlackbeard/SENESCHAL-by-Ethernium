{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ROBIN HOOD: Health",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "agentops.cli",
        "health",
        "--strict"
      ],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "ROBIN HOOD: Scan Path",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "agentops.cli",
        "scan",
        "--path",
        "${input:robinHoodScanPath}",
        "--source",
        "repo",
        "--fail-on-block"
      ],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "ROBIN HOOD: Pack Context",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "agentops.cli",
        "pack",
        "--path",
        "${input:robinHoodPackPath}",
        "--model",
        "local-long",
        "--max-tokens",
        "12000"
      ],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "ROBIN HOOD: Route",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "agentops.cli",
        "route",
        "--objective",
        "${input:robinHoodRouteObjective}",
        "--privacy",
        "local-first"
      ],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "ROBIN HOOD: Test",
      "type": "shell",
      "command": "pytest",
      "args": [
        "tests",
        "-q"
      ],
      "group": "test",
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "robinHoodScanPath",
      "type": "promptString",
      "description": "Path to scan with ROBIN HOOD",
      "default": "adversarial_cases"
    },
    {
      "id": "robinHoodPackPath",
      "type": "promptString",
      "description": "Path to pack with ROBIN HOOD",
      "default": "."
    },
    {
      "id": "robinHoodRouteObjective",
      "type": "promptString",
      "description": "Task objective to route with ROBIN HOOD",
      "default": "Fix typo in docs"
    }
  ]
}
